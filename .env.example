# Required by LangGraph nodes and live search_documentation integration tests.
# OPENAI_API_BASE can point to an OpenAI-compatible gateway if you do not use api.openai.com.
# The configured endpoint must support chat completions and embeddings.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Required by PGVector retrieval and live integration tests.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=10

# Table populated by scripts/import_knowledge_files.py.
PGVECTOR_TABLE_NAME=knowledge_base_documents
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_CHAT_MODEL=gpt-4o-mini
RERANK_MODEL=gpt-4o-mini
